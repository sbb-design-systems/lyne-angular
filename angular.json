{
  "$schema": "./node_modules/@angular/cli/lib/config/schema.json",
  "version": 1,
  "newProjectRoot": "src",
  "projects": {
    "angular": {
      "projectType": "library",
      "root": "src/angular",
      "sourceRoot": "src/angular",
      "prefix": "sbb",
      "architect": {
        "build": {
          "builder": "@angular/build:ng-packagr",
          "options": {
            "project": "src/angular/ng-package.json"
          },
          "configurations": {
            "production": {
              "tsConfig": "src/angular/tsconfig.lib.prod.json"
            },
            "development": {
              "tsConfig": "src/angular/tsconfig.lib.json"
            }
          },
          "defaultConfiguration": "production"
        },
        "test": {
          "builder": "@angular/build:unit-test",
          "defaultConfiguration": "browser",
          "options": {
            "tsConfig": "src/angular/tsconfig.spec.json",
            "exclude": ["src/angular/schematics/**/*.spec.ts"]
          },
          "configurations": {
            "browser": {
              "browsers": ["chromium"],
              "watch": true,
              "progress": true,
              "setupFiles": ["src/test-setup.ts"]
            },
            "ci": {
              "browsers": ["chromiumHeadless", "firefoxHeadless"],
              "coverage": false,
              "progress": false,
              "watch": false,
              "reporters": ["dot"],
              "setupFiles": ["src/test-setup.ts"]
            }
          }
        },
        "lint": {
          "builder": "@angular-eslint/builder:lint",
          "options": {
            "lintFilePatterns": ["src/angular/**/*.ts", "src/angular/**/*.html"],
            "eslintConfig": "src/angular/eslint.config.ts"
          }
        }
      }
    },
    "angular-experimental": {
      "projectType": "library",
      "root": "src/angular-experimental",
      "sourceRoot": "src/angular-experimental",
      "prefix": "lib",
      "architect": {
        "build": {
          "builder": "@angular/build:ng-packagr",
          "options": {
            "project": "src/angular-experimental/ng-package.json"
          },
          "configurations": {
            "production": {
              "tsConfig": "src/angular-experimental/tsconfig.lib.prod.json"
            },
            "development": {
              "tsConfig": "src/angular-experimental/tsconfig.lib.json"
            }
          },
          "defaultConfiguration": "production"
        },
        "test": {
          "builder": "@angular/build:unit-test",
          "defaultConfiguration": "browser",
          "options": {
            "tsConfig": "src/angular-experimental/tsconfig.spec.json"
          },
          "configurations": {
            "browser": {
              "browsers": ["chromium"],
              "watch": true,
              "progress": true,
              "setupFiles": ["src/test-setup.ts"]
            },
            "ci": {
              "browsers": ["chromiumHeadless", "firefoxHeadless"],
              "coverage": false,
              "progress": false,
              "watch": false,
              "reporters": ["dot"],
              "setupFiles": ["src/test-setup.ts"]
            }
          }
        },
        "lint": {
          "builder": "@angular-eslint/builder:lint",
          "options": {
            "lintFilePatterns": [
              "src/angular-experimental/**/*.ts",
              "src/angular-experimental/**/*.html"
            ],
            "eslintConfig": "src/angular-experimental/eslint.config.ts"
          }
        }
      }
    },
    "docs": {
      "projectType": "application",
      "schematics": {
        "@schematics/angular:component": {
          "style": "scss"
        }
      },
      "root": "",
      "sourceRoot": "src/docs",
      "prefix": "app",
      "architect": {
        "build": {
          "builder": "@angular/build:application",
          "options": {
            "sourceMap": {
              "scripts": true,
              "styles": true,
              "hidden": false,
              "vendor": true
            },
            "outputPath": "dist/docs",
            "index": "src/docs/index.html",
            "browser": "src/docs/main.ts",
            "tsConfig": "src/docs/tsconfig.json",
            "inlineStyleLanguage": "scss",
            "assets": [
              {
                "glob": "**/*",
                "input": "src/docs/assets",
                "output": "assets"
              },
              {
                "glob": "*-theme.css",
                "input": "node_modules/@sbb-esta/lyne-elements",
                "output": "assets/themes/angular/"
              },
              {
                "glob": "*-theme.css",
                "input": "node_modules/@sbb-esta/lyne-elements-experimental",
                "output": "assets/themes/angular-experimental/"
              },
              {
                "glob": "**/*.md",
                "input": "src/angular/",
                "output": "docs-content/overviews/angular/"
              },
              {
                "glob": "**/*.md",
                "input": "src/docs/app/angular/api",
                "output": "docs-content/api/angular"
              },
              {
                "glob": "**/*.{html,ts,css,scss}",
                "input": "src/docs/app/angular/examples/",
                "output": "docs-content/examples/angular/"
              },
              {
                "glob": "**/*.md",
                "input": "src/angular-experimental/",
                "output": "docs-content/overviews/angular-experimental/"
              },
              {
                "glob": "**/*.md",
                "input": "src/docs/app/angular-experimental/api",
                "output": "docs-content/api/angular-experimental"
              },
              {
                "glob": "**/*.{html,ts,css,scss}",
                "input": "src/docs/app/angular-experimental/examples/",
                "output": "docs-content/examples/angular-experimental/"
              }
            ],
            "styles": ["src/docs/styles.scss"]
          },
          "configurations": {
            "production": {
              "tsConfig": "src/docs/tsconfig.prod.json"
            },
            "development": {
              "tsConfig": "src/docs/tsconfig.json",
              "optimization": false,
              "sourceMap": true
            }
          },
          "defaultConfiguration": "production"
        },
        "serve": {
          "builder": "@angular/build:dev-server",
          "configurations": {
            "production": {
              "buildTarget": "docs:build:production"
            },
            "development": {
              "buildTarget": "docs:build:development"
            }
          },
          "defaultConfiguration": "development"
        },
        "lint": {
          "builder": "@angular-eslint/builder:lint",
          "options": {
            "lintFilePatterns": ["src/docs/**/*.ts", "src/docs/**/*.html"],
            "eslintConfig": "src/docs/eslint.config.ts"
          }
        },
        "test": {
          "builder": "@angular/build:unit-test",
          "defaultConfiguration": "browser",
          "options": {
            "tsConfig": "src/docs/tsconfig.spec.json"
          },
          "configurations": {
            "browser": {
              "browsers": ["chromium"],
              "watch": true,
              "progress": true,
              "setupFiles": ["src/test-setup.ts"]
            },
            "ci": {
              "browsers": ["chromiumHeadless", "firefoxHeadless"],
              "coverage": false,
              "progress": false,
              "watch": false,
              "reporters": ["dot"],
              "setupFiles": ["src/test-setup.ts"]
            }
          }
        }
      }
    }
  },
  "cli": {
    "schematicCollections": ["angular-eslint"],
    "analytics": false
  }
}

{
  "name": "lyne-angular",
  "version": "22.0.5",
  "scripts": {
    "postinstall": "run-s postinstall:playwright readme generate-keywords",
    "postinstall:playwright": "yarn playwright install",
    "ng": "ng",
    "start": "run-s compodoc:run 'ng serve docs'",
    "build:angular": "run-s 'ng build angular' build:angular:patch-version",
    "build:angular:patch-version": "node ./scripts/patch-package-version.mts",
    "build:angular:schematics": "tsc -p src/angular/schematics/tsconfig.json",
    "build:angular-experimental": "run-s 'ng build angular-experimental' build:angular-experimental:patch-version",
    "build:angular-experimental:patch-version": "node ./scripts/patch-package-version.mts",
    "build:docs": "run-s compodoc:run 'ng build docs' build:docs:patch-version",
    "build:docs:patch-version": "node ./scripts/patch-docs-version.mts",
    "build:stats": "node ./scripts/build-stats.mts",
    "build": "run-s build:angular build:angular:schematics build:angular-experimental build:docs build:stats",
    "test": "run-s test:*",
    "test:tsc": "run-s lint:tsc:*-spec",
    "test:angular": "ng test angular",
    "test:angular-schematics": "vitest run --config vitest.schematics.config.ts",
    "test:angular-experimental": "ng test angular-experimental",
    "test:docs": "ng test docs",
    "compodoc:run": "run-s compodoc:generate compodoc:api",
    "compodoc:generate": "compodoc -p tsconfig.doc.json -e json -d src/docs --minimal --disablePrivate --disableProtected --disableInternal --disableSourceCode",
    "compodoc:api": "tsx scripts/api-generator.mts",
    "generate-example": "node tools/generate-example/index.ts",
    "generate-keywords": "tsx scripts/generate-keywords.mts",
    "format": "prettier \"**/*\" --write --ignore-unknown",
    "lint": "ng lint",
    "lint:fix": "ng lint --fix",
    "readme": "node scripts/merge-readme.mts",
    "integrity": "run-p format readme",
    "update-lyne": "run-s update-lyne:upgrade readme",
    "update-lyne:upgrade": "yarn upgrade --non-interactive --scope @sbb-esta",
    "prepare-container": "echo 'noop'",
    "prepare": "husky"
  },
  "private": true,
  "type": "module",
  "dependencies": {
    "@angular/animations": "22.0.6",
    "@angular/cdk": "22.0.4",
    "@angular/common": "22.0.6",
    "@angular/compiler": "22.0.6",
    "@angular/core": "22.0.6",
    "@angular/forms": "22.0.6",
    "@angular/platform-browser": "22.0.6",
    "@angular/platform-browser-dynamic": "22.0.6",
    "@angular/router": "22.0.6",
    "@sbb-esta/lyne-design-tokens": "2.1.0",
    "@sbb-esta/lyne-elements": "npm:@sbb-esta/lyne-elements-dev@v5-dev",
    "@sbb-esta/lyne-elements-experimental": "npm:@sbb-esta/lyne-elements-experimental-dev@v5-dev",
    "@stackblitz/sdk": "1.11.1",
    "rxjs": "7.8.2",
    "tslib": "2.8.1"
  },
  "devDependencies": {
    "@angular-devkit/core": "22.0.6",
    "@angular-devkit/schematics": "22.0.6",
    "@angular/build": "22.0.6",
    "@angular/cli": "22.0.6",
    "@angular/compiler-cli": "22.0.6",
    "@commitlint/cli": "21.2.1",
    "@commitlint/config-conventional": "21.2.0",
    "@compodoc/compodoc": "2.0.0",
    "@eslint/js": "10.0.1",
    "@schematics/angular": "22.0.6",
    "@types/node": "24.13.3",
    "@vitest/browser-playwright": "4.1.10",
    "@vitest/coverage-v8": "4.1.10",
    "angular-eslint": "22.1.0",
    "custom-elements-manifest": "2.1.0",
    "eslint": "10.7.0",
    "eslint-config-prettier": "10.1.8",
    "eslint-plugin-import-x": "4.17.1",
    "github-slugger": "2.0.0",
    "globals": "17.7.0",
    "highlight.js": "11.11.1",
    "husky": "9.1.7",
    "jiti": "2.7.0",
    "lint-staged": "17.0.8",
    "marked": "18.0.6",
    "marked-highlight": "2.2.4",
    "ng-packagr": "22.0.1",
    "npm-run-all2": "9.0.2",
    "playwright": "1.61.1",
    "prettier": "3.9.5",
    "tsx": "4.23.0",
    "typescript": "6.0.3",
    "typescript-eslint": "8.63.0",
    "vitest": "4.1.10"
  },
  "prettier": {
    "singleQuote": true,
    "endOfLine": "lf",
    "printWidth": 100,
    "overrides": [
      {
        "files": "*.html",
        "options": {
          "parser": "angular"
        }
      }
    ]
  },
  "lint-staged": {
    "*.{js,ts}": [
      "eslint --fix --no-ignore"
    ],
    "**/*": "prettier --write --ignore-unknown"
  }
}

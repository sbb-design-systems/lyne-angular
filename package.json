{
  "name": "lyne-angular",
  "version": "21.7.0",
  "scripts": {
    "postinstall": "run-s postinstall:playwright readme",
    "postinstall:playwright": "yarn playwright install",
    "ng": "ng",
    "start": "run-s compodoc:run generate-selector-map 'ng serve docs'",
    "build:angular": "ng build angular",
    "postbuild:angular": "node ./scripts/patch-package-version.mts",
    "build:angular-experimental": "ng build angular-experimental",
    "postbuild:angular-experimental": "node ./scripts/patch-package-version.mts",
    "build:docs": "run-s compodoc:run generate-selector-map 'ng build docs'",
    "postbuild:docs": "node ./scripts/patch-docs-version.mts",
    "build": "yarn -s build:angular && yarn -s build:angular-experimental && yarn -s build:docs",
    "test": "npm-run-all --sequential test:*",
    "test:angular": "ng test angular",
    "test:angular-experimental": "ng test angular-experimental",
    "test:docs": "ng test docs",
    "compodoc:run": "run-s compodoc:generate compodoc:api",
    "compodoc:generate": "compodoc -p tsconfig.doc.json -e json -d src/docs --minimal --disablePrivate --disableProtected --disableInternal --disableSourceCode",
    "compodoc:api": "tsx scripts/api-generator.mts",
    "generate-selector-map": "tsx scripts/generate-selector-map.mts",
    "format": "prettier \"**/*\" --write --ignore-unknown",
    "lint": "ng lint",
    "lint fix": "ng lint --fix",
    "readme": "node scripts/merge-readme.mts",
    "integrity": "run-p format readme",
    "update-lyne": "run-s update-lyne:upgrade readme",
    "update-lyne:upgrade": "yarn upgrade --non-interactive --scope @sbb-esta",
    "prepare": "husky"
  },
  "private": true,
  "type": "module",
  "dependencies": {
    "@angular/animations": "21.2.15",
    "@angular/cdk": "21.2.13",
    "@angular/common": "21.2.15",
    "@angular/compiler": "21.2.15",
    "@angular/core": "21.2.15",
    "@angular/forms": "21.2.15",
    "@angular/platform-browser": "21.2.15",
    "@angular/platform-browser-dynamic": "21.2.15",
    "@angular/router": "21.2.15",
    "@sbb-esta/lyne-design-tokens": "2.1.0",
    "@sbb-esta/lyne-elements": "npm:@sbb-esta/lyne-elements-dev@v4-dev",
    "@sbb-esta/lyne-elements-experimental": "npm:@sbb-esta/lyne-elements-experimental-dev@v4-dev",
    "@stackblitz/sdk": "1.11.0",
    "rxjs": "7.8.2",
    "tslib": "2.8.1",
    "zone.js": "0.16.0"
  },
  "devDependencies": {
    "@angular/build": "21.2.13",
    "@angular/cli": "21.2.13",
    "@angular/compiler-cli": "21.2.15",
    "@commitlint/cli": "21.0.2",
    "@commitlint/config-conventional": "21.0.2",
    "@compodoc/compodoc": "1.2.1",
    "@eslint/js": "10.0.1",
    "@types/node": "24.12.4",
    "@vitest/browser-playwright": "4.1.8",
    "@vitest/coverage-v8": "4.1.8",
    "angular-eslint": "21.4.0",
    "custom-elements-manifest": "2.1.0",
    "eslint": "10.4.1",
    "eslint-config-prettier": "10.1.8",
    "eslint-plugin-import-x": "4.16.2",
    "github-slugger": "2.0.0",
    "globals": "17.6.0",
    "highlight.js": "11.11.1",
    "husky": "9.1.7",
    "lint-staged": "17.0.7",
    "marked": "18.0.4",
    "marked-highlight": "2.2.4",
    "ng-packagr": "21.2.5",
    "npm-run-all2": "9.0.1",
    "playwright": "1.60.0",
    "prettier": "3.8.3",
    "tsx": "4.22.4",
    "typescript": "5.9.3",
    "typescript-eslint": "8.60.1",
    "vitest": "4.1.8"
  },
  "prettier": {
    "singleQuote": true,
    "endOfLine": "lf",
    "printWidth": 100
  },
  "lint-staged": {
    "*.{js,ts}": [
      "eslint --fix --no-ignore"
    ],
    "**/*": "prettier --write --ignore-unknown"
  }
}
